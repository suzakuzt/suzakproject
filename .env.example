# ============================================================
# Festival Activity H5 部署环境变量模板
# ============================================================
#
# 使用方式：
# 1. 如果服务器用 docker-compose / 部署包根目录启动：
#    cp .env.example .env
# 2. 如果服务器直接用源码启动后端：
#    cp backend/.env.example backend/.env
# 3. 后端代码只读取 GAOKAO_H5_MYSQL_*；不要只配置 EXTERNAL_MYSQL_*。
#


# ============================================================
# MySQL 数据库配置
# ============================================================

