GAOKAO_H5_DB_PATH=
GAOKAO_H5_MYSQL_HOST=192.168.11.43
GAOKAO_H5_MYSQL_PORT=3306
GAOKAO_H5_MYSQL_DATABASE=festival-activity
GAOKAO_H5_MYSQL_USER=festival-activity
GAOKAO_H5_MYSQL_PASSWORD=1qa2wsx#EDC
GAOKAO_H5_MYSQL_CONNECT_TIMEOUT=10


