GAOKAO_H5_MYSQL_PORT=3306
GAOKAO_H5_MYSQL_DATABASE=gaokao_h5
GAOKAO_H5_MYSQL_USER=root
GAOKAO_H5_MYSQL_PASSWORD=
GAOKAO_H5_MYSQL_CONNECT_TIMEOUT=10

PORTAL_BASE_URL=https://portal.kpcc-tech.com
PORTAL_USERNAME=
PORTAL_PASSWORD=

