# ============================================================
# Festival Activity H5 后端环境变量模板
# ============================================================
#
# 使用方式：
# 1. 运维在正式服务器源码目录下复制本文件：
#    cp backend/.env.example backend/.env
# 2. 按下面标注填写 backend/.env。
# 3. backend/.env 只放在服务器本地，不提交 Git。
# 4. 后端代码只读取 GAOKAO_H5_MYSQL_*；不要只配置 EXTERNAL_MYSQL_*。
#


# ============================================================
# 生产环境必填
# ============================================================

# 【运维/DBA填写】MySQL 数据库配置。
# 说明：生产环境必须使用 MySQL；以下连接信息由运维/DBA提供。
GAOKAO_H5_DB_ENGINE=mysql
GAOKAO_H5_DB_PATH=
GAOKAO_H5_MYSQL_HOST=192.168.11.43
GAOKAO_H5_MYSQL_PORT=3306
GAOKAO_H5_MYSQL_DATABASE=festival-activity
GAOKAO_H5_MYSQL_USER=festival-activity
GAOKAO_H5_MYSQL_PASSWORD=1qa2wsx#EDC
GAOKAO_H5_MYSQL_CONNECT_TIMEOUT=10

# 【业务/开发提供，运维照填】Hermes 门户配置。
# 说明：发券接口必填；账号密码由业务/开发提供给运维配置到服务器。
PORTAL_BASE_URL=https://portal.kpcc-tech.com
PORTAL_USERNAME=zt25156
PORTAL_PASSWORD=Aa123456

# 【业务/开发提供，运维照填】管理接口 Token。
# 说明：/api/admin/* 接口鉴权使用，由业务/开发生成后提供给运维。
GAOKAO_H5_ADMIN_TOKEN=9u9GCpHHu-4T8D-_h6jTvgFbGjA1y72iOmNvgSec0Mg


# ============================================================
# 生产环境可选
# ============================================================

# 【运维填写，可选】海报图片保存目录。
# 说明：生产环境建议配置到持久化目录；不配置则使用后端默认本地目录。
GAOKAO_H5_POSTER_DIR=

# 【业务/开发提供，可选】AI 解签配置。
# 说明：不填 DEEPSEEK_API_KEY 时会使用本地兜底文案，不影响抽签和领券主流程。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_MAX_TOKENS=260


# ============================================================
# 本地开发专用
# ============================================================

# 【开发本地使用】SQLite 配置。
# 说明：仅本地开发/自动化测试使用，生产环境不要开启。
# GAOKAO_H5_DB_ENGINE=sqlite
# GAOKAO_H5_DB_PATH=backend/data/gaokao_h5_dev.sqlite3


# ============================================================
# 旧版单券兜底，通常不需要
# ============================================================

# 【通常不填写】当前正式发券配置来自 MySQL 表 coupon_issue_config。
# 以下配置仅用于开发明确要求的单券兜底场景，生产正常不需要填写。
HERMES_COUPON_TITLE=
HERMES_ID=
HERMES_REF_ID=
HERMES_REF_TYPE=
HERMES_START_TIME=
HERMES_END_TIME=
HERMES_FACE_VALUE=
